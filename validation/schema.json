{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["mode", "sections", "cases", "java"],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["legacy", "current"]
    },
    "sections": {
      "type": "object",
      "required": ["A", "B", "C", "D"],
      "additionalProperties": false,
      "properties": {
        "A": {
          "type": "string"
        },
        "B": {
          "type": "string"
        },
        "C": {
          "type": "string"
        },
        "D": {
          "type": "string"
        }
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "priority", "preconditions", "steps", "expected", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TC-\\d{3}$"
          },
          "category": {
            "type": "string",
            "enum": ["正常系", "異常系", "境界値", "セキュリティ"]
          },
          "priority": {
            "type": "string",
            "enum": ["高", "中", "低"]
          },
          "preconditions": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "java": {
      "type": "object",
      "required": ["code", "testCount", "hasJavaFence", "publicClassName", "imports", "annotations"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "testCount": {
          "type": "integer",
          "minimum": 0
        },
        "hasJavaFence": {
          "type": "boolean"
        },
        "publicClassName": {
          "type": ["string", "null"]
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["BeforeEach", "AfterEach", "Test"]
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "legacy"
          }
        }
      },
      "then": {
        "properties": {
          "sections": {
            "properties": {
              "A": {
                "minLength": 1
              }
            }
          },
          "cases": {
            "minItems": 1
          },
          "java": {
            "properties": {
              "hasJavaFence": {
                "const": true
              },
              "testCount": {
                "minimum": 3
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "current"
          }
        }
      },
      "then": {
        "properties": {
          "sections": {
            "properties": {
              "B": {
                "minLength": 1
              }
            }
          },
          "java": {
            "properties": {
              "hasJavaFence": {
                "const": true
              },
              "testCount": {
                "minimum": 2
              }
            }
          }
        }
      }
    }
  ]
}